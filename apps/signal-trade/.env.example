# Twitter/X auth
# Required when using twitter.community_count
TWITTER_CT0=
# Required when using twitter.community_count
TWITTER_AUTH_TOKEN=
# Optional. Falls back to the built-in runtime default when omitted.
TWITTER_BEARER_TOKEN=

# XXYY protected endpoints
# Optional. Only needed when XXYY follow/tag_holder endpoints require login state.
XXYY_AUTHORIZATION=
# Optional. Only needed when XXYY follow/tag_holder endpoints require login state.
XXYY_INFO_TOKEN=
# Optional. Only needed when XXYY follow/tag_holder endpoints require login state.
XXYY_COOKIE=
