{
  "forwards": [
    {
      "from": "@binance_announcements",
      "to": "@my_archive"
    },
    {
      "from": "@binance_announcements",
      "to": "@vip_channel",
      "keywords": ["上线", "Alpha", "新币"]
    },
    {
      "from": "@trading_group",
      "to": ["@expert_signals", "@backup_channel"],
      "users": ["@expert_1", "@expert_2", 123456789],
      "silent": true
    }
  ],
  "groups": [
    {
      "id": "address_monitor",
      "name": "KOL 地址监控",
      "source": -1001234567890,
      "rules": [
        {
          "targets": ["@address_alerts"],
          "forward_mode": "copy",
          "filters": {
            "mode": "include",
            "rules": [
              {
                "type": "user_conditional",
                "config": {
                  "users": ["@kol_1", "@kol_2"],
                  "conditions": [
                    {
                      "type": "regex",
                      "config": {
                        "pattern": "(?:0x[a-fA-F0-9]{40}|[1-9A-HJ-NP-Za-km-z]{32,44})",
                        "description": "匹配加密货币地址"
                      }
                    }
                  ],
                  "condition_logic": "any"
                }
              }
            ]
          }
        }
      ]
    },
    {
      "id": "paused_example",
      "name": "临时暂停示例",
      "enabled": false
    }
  ]
}
