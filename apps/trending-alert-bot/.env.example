# Target Telegram bot tokens
BSC_TELEGRAM_BOT_TOKEN=
SOL_TELEGRAM_BOT_TOKEN=
BASE_TELEGRAM_BOT_TOKEN=
ETH_TELEGRAM_BOT_TOKEN=
ROBIN_TELEGRAM_BOT_TOKEN=
MULTI_TELEGRAM_BOT_TOKEN=

# Runtime env consumed by config.py.
# These BOT_* values are normally injected by main.py from the selected target.
# They are listed here so every supported env field is visible.
BOT_CHAIN=sol
BOT_CHAINS=["sol"]
BOT_TELEGRAM_TOKEN=
BOT_DATA_DIR=data/sol-bot
BOT_CHECK_INTERVAL=15
BOT_NOTIFY_COOLDOWN_HOURS=24
BOT_MULTIPLIER_CONFIRMATIONS=2
BOT_NOTIFICATION_TYPES=["trending","anomaly"]
BOT_CHAIN_ALLOWLIST_JSON={"sol":{}}
BOT_DRY_RUN=false

# Narrative analysis (disabled by default)
NARRATIVE_ENABLED=false
NARRATIVE_PROVIDER=xai
NARRATIVE_CACHE_TTL_HOURS=12
NARRATIVE_MIN_EVIDENCE=3
NARRATIVE_TIMEOUT_SECONDS=20
XAI_API_KEY=

# PM2 Python interpreter override
PYTHON=
